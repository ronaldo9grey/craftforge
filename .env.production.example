# =============================================================
# CraftForge 生产环境配置模板
# 部署时复制为 .env.production 并填入真实密钥
# 部署脚本会自动生成 JWT_SECRET（如检测到占位符）
# =============================================================

# ---------- 服务器 ----------
NODE_ENV=production
NGINX_PORT=80

# ---------- 后端 ----------
PORT=3001

# JWT 密钥（生产环境必须修改！建议用 openssl rand -hex 32 生成）
# 注意：deploy.sh 检测到 CHANGE_ME 时会自动替换为随机 64 字节强密钥
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING_a1b2c3d4e5f6
JWT_EXPIRES_IN=7d

# APP_TOKEN（前后端必须一致，建议 openssl rand -hex 24）
APP_TOKEN=CHANGE_ME_APP_TOKEN

# CORS（生产环境改为你的域名）
CORS_ORIGIN=http://localhost

# ---------- DeepSeek AI ----------
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_API_KEY_HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- 腾讯云 TTS ----------
TENCENT_SECRET_ID=AKID_YOUR_TENCENT_SECRET_ID_HERE
TENCENT_SECRET_KEY=YOUR_TENCENT_SECRET_KEY_HERE
TENCENT_REGION=ap-guangzhou
TENCENT_VOICE_TYPE=501000
TENCENT_SAMPLE_RATE=16000
TENCENT_VOICE_SPEED=0
TENCENT_VOICE_VOLUME=0

# ---------- 日志 ----------
LOG_DIR=logs

# ---------- 备份（被 deploy/backup.sh 读取）----------
# BACKUP_DIR 默认 /opt/craftforge/backups
# RETAIN_DAYS 默认 7
