# 后端运行端口
PORT=3001

# 前端访问后端必须携带的 APP_TOKEN（与前端 VITE_APP_TOKEN 保持一致）
APP_TOKEN=请从 CraftForge 工程师处获取

# DeepSeek 配置（仅服务器端持有，不会暴露到前端）
DEEPSEEK_API_KEY=请填入你的 DeepSeek key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 日志目录（相对后端项目根）
LOG_DIR=logs

# CORS 白名单：开发用 *，生产建议填具体域名（多个用逗号分隔）
CORS_ORIGIN=*
