# 后端运行端口
PORT=3001

# 前端访问后端必须携带的 APP_TOKEN（与前端 VITE_APP_TOKEN 保持一致）
APP_TOKEN=请从 CraftForge 工程师处获取

# DeepSeek 配置（仅服务器端持有，不会暴露到前端）
DEEPSEEK_API_KEY=请填入你的 DeepSeek key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 腾讯云 TTS 配置（仅服务器端持有，不会暴露到前端）
# 控制台地址：https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=请填入你的 SecretId（AKID 开头）
TENCENT_SECRET_KEY=请填入你的 SecretKey（绝密，切勿提交到 git）
TENCENT_REGION=ap-guangzhou
# 音色 ID，1003=智逍遥（沉稳中年男）；其他可选见 https://cloud.tencent.com/document/product/1073/92668
TENCENT_VOICE_TYPE=1003
# 采样率（8000/16000/24000），16000 已足够清晰
TENCENT_SAMPLE_RATE=16000
# 语速 -2 ~ 2，0 默认，老张人设建议保持 0 或 -1（略慢）
TENCENT_VOICE_SPEED=0
# 音量 -10 ~ 10，0 默认
TENCENT_VOICE_VOLUME=0

# 日志目录（相对后端项目根）
LOG_DIR=logs

# CORS 白名单：开发用 *，生产建议填具体域名（多个用逗号分隔）
CORS_ORIGIN=*
